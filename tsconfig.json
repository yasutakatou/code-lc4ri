{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2019",
        "lib": ["ES2019"],
        "outDir": "out",
        "sourceMap": true,
        "strict": true,
        "rootDir": "src",
        "types": [
          "vscode",
          "node"
        ]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", ".vscode-test", "out", "out-test", "test", "bin"]
}
